{
	"mcpServers": {
		"hashicorp-vault": {
			"comment": "HashiCorp Vault MCP - primary secrets source. Path: cubbyhole/internal-erp/db",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-vault"
			],
			"env": {
				"VAULT_ADDR": "https://45.88.223.83:31313",
				"VAULT_TOKEN": "hvs.CAESIC0nSYZlc92KbjE36r_Vncz-MznLpY0eMplhN_V6FrVaGh4KHGh2cy5jU3Q2djJMWjc2bWJPYkZhN3ZSN1JBcUc",
				"VAULT_SKIP_VERIFY": "true"
			}
		},
		"postgresql": {
			"comment": "PostgreSQL MCP - DB_PASSWORD from cubbyhole/internal-erp/db",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-postgres"
			],
			"env": {
				"VAULT_ADDR": "https://45.88.223.83:31313",
				"VAULT_TOKEN": "hvs.CAESIC0nSYZlc92KbjE36r_Vncz-MznLpY0eMplhN_V6FrVaGh4KHGh2cy5jU3Q2djJMWjc2bWJPYkZhN3ZSN1JBcUc",
				"VAULT_SECRET_PATH": "cubbyhole/internal-erp/db",
				"VAULT_SECRET_KEY": "DB_PASSWORD"
			}
		},
		"directus": {
			"comment": "Directus MCP - DIRECTUS_TOKEN from cubbyhole/internal-erp/db. Server: bs4.expertflow.com (Directus v11.12.0, MCP enabled)",
			"command": "npx",
			"args": [
				"-y",
				"@directus/mcp-server"
			],
			"env": {
				"DIRECTUS_URL": "https://bs4.expertflow.com",
				"VAULT_ADDR": "https://45.88.223.83:31313",
				"VAULT_TOKEN": "hvs.CAESIC0nSYZlc92KbjE36r_Vncz-MznLpY0eMplhN_V6FrVaGh4KHGh2cy5jU3Q2djJMWjc2bWJPYkZhN3ZSN1JBcUc",
				"VAULT_SECRET_PATH": "cubbyhole/internal-erp/db",
				"VAULT_TOKEN_FIELD": "DIRECTUS_TOKEN"
			}
		},
		"bmad": {
			"comment": "BMAD Method MCP v6.2.0 - BMADMonorepoEFInternalTools. Agents: analyst, architect, dev, pm, qa, sm, ux-designer, tech-writer. Workflows: create-prd, create-architecture, create-epics-and-stories, dev-story, sprint-planning, sprint-status, retrospective, document-project, generate-project-context, qa-generate-e2e-tests, quick-flow.",
			"command": "npx",
			"args": [
				"-y",
				"bmad-method",
				"mcp"
			],
			"env": {
				"BMAD_ROOT": "${workspaceFolder}/_bmad",
				"BMAD_OUTPUT": "${workspaceFolder}/_bmad-output",
				"BMAD_PLANNING_ARTIFACTS": "${workspaceFolder}/_bmad-output/planning-artifacts",
				"BMAD_IMPLEMENTATION_ARTIFACTS": "${workspaceFolder}/_bmad-output/implementation-artifacts",
				"BMAD_PROJECT_KNOWLEDGE": "${workspaceFolder}/docs",
				"BMAD_PROJECT_NAME": "BMADMonorepoEFInternalTools",
				"BMAD_USER": "Andreas"
			}
		},
		"speckit": {
			"comment": "GitHub SpecKit MCP - implementation specs and API contracts. Specs live in _bmad-output/planning-artifacts and _bmad-output/implementation-artifacts.",
			"command": "npx",
			"args": [
				"-y",
				"@github/spec-kit-mcp"
			],
			"env": {
				"SPECS_PATH": "${workspaceFolder}/_bmad-output",
				"PLANNING_ARTIFACTS": "${workspaceFolder}/_bmad-output/planning-artifacts",
				"IMPLEMENTATION_ARTIFACTS": "${workspaceFolder}/_bmad-output/implementation-artifacts",
				"VAULT_ADDR": "https://45.88.223.83:31313",
				"VAULT_TOKEN": "hvs.CAESIC0nSYZlc92KbjE36r_Vncz-MznLpY0eMplhN_V6FrVaGh4KHGh2cy5jU3Q2djJMWjc2bWJPYkZhN3ZSN1JBcUc",
				"VAULT_SECRET_PATH": "cubbyhole/internal-erp/db",
				"VAULT_SECRET_KEY": "GITHUB_TOKEN"
			}
		},
		"playwright": {
			"comment": "Playwright MCP - browser automation and end-to-end testing",
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest"
			],
			"env": {
				"PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}/.playwright"
			},
			"alwaysAllow": [
				"browser_navigate",
				"browser_click",
				"browser_snapshot",
				"browser_take_screenshot",
				"browser_fill_form",
				"browser_wait_for"
			]
		},
		"vmware": {
			"comment": "VMware MCP - GCP VMware Engine infrastructure management",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-vmware"
			],
			"env": {
				"VAULT_ADDR": "https://45.88.223.83:31313",
				"VAULT_TOKEN": "hvs.CAESIC0nSYZlc92KbjE36r_Vncz-MznLpY0eMplhN_V6FrVaGh4KHGh2cy5jU3Q2djJMWjc2bWJPYkZhN3ZSN1JBcUc",
				"VAULT_SECRET_PATH": "cubbyhole/internal-erp/db",
				"VAULT_SECRET_KEY": "ADMIN_PASSWORD",
				"VMWARE_INSECURE": "true"
			}
		},
		"lint": {
			"comment": "Lint MCP - ESLint, Sonar, Gherkin, requirement-linter pre/post hooks",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-lint"
			],
			"env": {
				"LINT_CONFIG_PATH": "${workspaceFolder}/.eslintrc.json",
				"GHERKIN_FEATURES_PATH": "${workspaceFolder}/features",
				"REQUIREMENT_LINTER_DOCS": "${workspaceFolder}/docs/bmad",
				"VAULT_ADDR": "https://45.88.223.83:31313",
				"VAULT_TOKEN": "hvs.CAESIC0nSYZlc92KbjE36r_Vncz-MznLpY0eMplhN_V6FrVaGh4KHGh2cy5jU3Q2djJMWjc2bWJPYkZhN3ZSN1JBcUc",
				"VAULT_SECRET_PATH": "cubbyhole/internal-erp/db",
				"VAULT_SECRET_KEY": "SONAR_TOKEN"
			}
		}
	}
}