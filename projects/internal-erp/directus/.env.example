# Copy to `.env` in THIS DIRECTORY ONLY:
#   projects/internal-erp/directus/.env
# (next to docker-compose.yml). Docker Compose `env_file: .env` resolves relative to
# that folder — a repo-root `.env` is NOT used by this Directus stack.
#
# Never put real passwords, KEY, or SECRET in this file — it is committed to git.
# Start Cloud SQL Auth Proxy on the host binding 127.0.0.1:5432 before `docker compose up`.

# --- Directus secrets (generate strong random strings) ---
KEY=
SECRET=

# --- Public URL (local) ---
PUBLIC_URL=http://localhost:8055

# Optional — after PostgreSQL/Directus metadata changes, stale collection fields in the UI are often
# schema cache. For local dev you can disable: CACHE_SCHEMA=false  (then restart Directus).
# Or keep default cache and restart the container + hard-refresh the browser (or clear site data).

# --- PostgreSQL via Cloud SQL Auth Proxy on host ---
# From inside the container, the proxy is reached at host.docker.internal (see docker-compose extra_hosts).
DB_CLIENT=pg
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=bidstruct4
# Runtime account: sterile_dev (no blanket RLS bypass). Break-glass / migrations: bs4_dev — see architecture ADR-13 §8.1 and docs/sql/setup-sterile-dev.sql
DB_USER=sterile_dev
DB_PASSWORD=

# Optional — local only. Put the real value in `.env` here (gitignored). Used by
# `scripts/run-fix-rls-invoice-dml.ps1` if `$env:BS4_DEV_PASSWORD` is unset.
# Use double quotes if the password contains # or spaces: BS4_DEV_PASSWORD="a#b"
# Verify without printing: .\scripts\run-fix-rls-invoice-dml.ps1 -VerifyEnvOnly
# Never commit a filled value. Rotate if this file is ever exposed.
# BS4_DEV_PASSWORD=

# Optional: only if directus_* / ERP tables are not in public.
# Mixed-case schema (e.g. BS4Prod09Feb2026): use exact catalog name; this compose image patches Directus for ::regnamespace.
# Single schema:
# DB_SEARCH_PATH=BS4Prod09Feb2026
# Multiple schemas (e.g. ERP schema + public for PostGIS) — use indexed vars (NOT a comma in one string):
# DB_SEARCH_PATH__0=BS4Prod09Feb2026
# DB_SEARCH_PATH__1=public

# --- First-time admin (Directus bootstrap) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Story 1-10 — RLS hook (optional; default on). Set false only to debug without per-user RLS context.
# RLS_USER_CONTEXT_ENABLED=true
# PostgreSQL role for SET LOCAL ROLE (must exist; NOT "public" — that is not a role). See docs/sql/create-rls-session-role.sql
# RLS_SESSION_ROLE=directus_rls_subject

# --- Story 1-8 — Google Workspace OIDC (JIT @expertflow.com) — see docs/story-1-8-google-sso.md ---
# PUBLIC_URL must match the URL you use in the browser (127.0.0.1 vs localhost).
# AUTH_PROVIDERS=google
# AUTH_GOOGLE_DRIVER=openid
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com
# AUTH_GOOGLE_IDENTIFIER_KEY=email
# AUTH_GOOGLE_SCOPE=openid profile email
# AUTH_GOOGLE_ALLOW_PUBLIC_REGISTRATION=true
# AUTH_GOOGLE_REQUIRE_VERIFIED_EMAIL=true
# AUTH_GOOGLE_DEFAULT_ROLE_ID=
# AUTH_GOOGLE_LABEL=Google
# AUTH_GOOGLE_SYNC_USER_INFO=true
# Keep local admin login during rollout (omit or false):
# AUTH_DISABLE_DEFAULT=false
