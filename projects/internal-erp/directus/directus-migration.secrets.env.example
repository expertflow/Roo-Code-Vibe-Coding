# =============================================================================
# COPY TO: directus-migration.secrets.env (gitignored) — keep filled for repeat deploys / updates.
# =============================================================================
# Used by: build-directus-vm-env.ps1, start-cloud-sql-proxy.ps1, run-owner-sql-through-proxy.ps1,
#          preflight-gcp-migrate-from-secrets.ps1 (GCP_DEPLOYER_KEY_FILE only).
#
# WHAT TO PUT HERE (automation-friendly — no interactive prompts if all set):
#   • Directus app secrets: KEY, SECRET, PUBLIC_URL (must match browser URL + Google OAuth URIs).
#   • Postgres (Cloud SQL) for Directus runtime: DB_* with DB_USER=sterile_dev and DB_PASSWORD.
#   • Admin bootstrap: ADMIN_EMAIL, ADMIN_PASSWORD (break-glass; existing DB may ignore bootstrap).
#   • Google SSO: AUTH_GOOGLE_* (client id/secret, default role id, etc.).
#   • Optional paths (no secrets in the path string itself): GOOGLE_APPLICATION_CREDENTIALS,
#     CLOUD_SQL_PROXY_EXE, GCP_DEPLOYER_KEY_FILE — point at JSON keys under .secrets/ (gitignored).
#   • Owner-only DB (never uploaded to VM as Directus user): BS4_DEV_USER, BS4_DEV_PASSWORD.
#   • Cloud SQL instance name: CLOUDSQL_INSTANCE (not a password).
#
# DO NOT commit this file. JSON keys live in projects/internal-erp/directus/.secrets/ (gitignored).
# =============================================================================

# --- Cloud SQL (proxy + metadata) ---
CLOUDSQL_INSTANCE=expertflowerp:europe-west6:expertflowerp1
# Optional: non-interactive proxy auth (path to JSON key for an SA with roles/cloudsql.client).
# If unset, proxy uses Application Default Credentials (gcloud auth application-default login — one-time interactive).
# GOOGLE_APPLICATION_CREDENTIALS=D:\secrets\your-sql-client-sa.json

# Optional: full path to cloud-sql-proxy / cloud_sql_proxy binary if not on PATH.
# CLOUD_SQL_PROXY_EXE=C:\tools\cloud-sql-proxy.x64.exe

# Optional: SA JSON for non-interactive gcloud (Invoke-directus-gcp-migration.ps1 runs preflight).
# Leave unset if `gcloud auth login` already works for expertflowerp.
# GCP_DEPLOYER_KEY_FILE=D:\VibeCode\BMADMonorepoEFInternalTools\projects\internal-erp\directus\.secrets\deployer-sa.json

# --- Directus runtime (VM .env) — DB user MUST be sterile_dev ---
KEY=
SECRET=
# Production URL users open (HTTPS). Add this origin to Google OAuth authorized redirect URIs.
PUBLIC_URL=https://directus.example.com

DB_CLIENT=pg
# Same pattern as local: proxy on VM host :5432, container uses host.docker.internal (see docker-compose extra_hosts).
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=bidstruct4
DB_USER=sterile_dev
DB_PASSWORD=

DB_SEARCH_PATH__0=BS4Prod09Feb2026
DB_SEARCH_PATH__1=public

# Bootstrap / break-glass (existing DB usually skips bootstrap).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google OIDC (same as local if you reuse the OAuth client; update redirect URIs for PUBLIC_URL).
AUTH_GOOGLE_DEFAULT_ROLE_ID=
AUTH_PROVIDERS=google
AUTH_GOOGLE_DRIVER=openid
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com
AUTH_GOOGLE_IDENTIFIER_KEY=email
AUTH_GOOGLE_SCOPE=openid profile email
AUTH_GOOGLE_ALLOW_PUBLIC_REGISTRATION=true
AUTH_GOOGLE_REQUIRE_VERIFIED_EMAIL=true
AUTH_GOOGLE_LABEL=Google
AUTH_GOOGLE_SYNC_USER_INFO=true
AUTH_DISABLE_DEFAULT=false

# --- Owner / DBA SQL only (never copy to VM Directus .env). Used by run-owner-sql-through-proxy.ps1 ---
# BS4_DEV_USER=bs4_dev
# BS4_DEV_PASSWORD=
