# =============================================================================
# COPY TO: directus-vm-migrate.env (gitignored) — targets & deploy toggles (no app passwords here).
# =============================================================================
# Used by: migrate-directus-to-vm.ps1, Invoke-directus-gcp-migration.ps1, preflight (reads GCP_PROJECT).
#
# WHAT TO PUT HERE:
#   • GCP_PROJECT, GCP_ZONE, GCP_VM_NAME — which VM to push to.
#   • LOCAL_DIRECTUS_DIR — absolute path to this folder on your PC (recommended for CI / scheduled tasks).
#   • VM_DEPLOY_PATH — extract path on the VM (e.g. /opt/directus).
#   • VM_USE_SUDO_FOR_DEPLOY — true/false if extract needs sudo.
#   • GCP_SSH_USER — only if gcloud SSH picks the wrong Unix account.
#   • SKIP_BUILD, DRY_RUN — optional speed / dry-run toggles.
#
# App secrets (KEY, DB_PASSWORD, OAuth, etc.) belong in directus-migration.secrets.env, not here.
# Invoke-directus-gcp-migration.ps1 uploads generated directus-vm-runtime.env; you usually do not need VM_ENV_FILE_TO_UPLOAD.
#
# Future updates: same flow — .\Invoke-directus-gcp-migration.ps1 from projects/internal-erp/directus
# =============================================================================
# Lines starting with # are ignored by the script.

# --- GCP / SSH (required) ---
GCP_PROJECT=expertflowerp
GCP_ZONE=europe-west6-a
GCP_VM_NAME=directus-erp

# If OS Login / username differs from your local Windows user, set explicitly (optional).
# Leave empty to let `gcloud compute ssh` use defaults.
# GCP_SSH_USER=

# --- Paths (required) ---
# Absolute path to this Directus folder on your laptop (Dockerfile, docker-compose.yml).
# Default if unset: folder containing migrate-directus-to-vm.ps1
# LOCAL_DIRECTUS_DIR=D:\VibeCode\BMADMonorepoEFInternalTools\projects\internal-erp\directus

# Where the tarball is extracted on the VM (must be writable by your SSH user or use sudo in script).
VM_DEPLOY_PATH=/opt/directus

# If true, extract with sudo and chown to GCP_SSH_USER (set GCP_SSH_USER when using sudo).
VM_USE_SUDO_FOR_DEPLOY=true

# --- Runtime on VM (you must already have these before first `up`) ---
# The script does NOT upload .env by default (secrets stay off your laptop copy flow if you prefer).
# Set to an absolute path on Windows to a file to SCP as .env on the VM after extract (optional).
# VM_ENV_FILE_TO_UPLOAD=

# --- Compose ---
# Compose file name under VM_DEPLOY_PATH (default docker-compose.yml).
# VM_COMPOSE_FILE=docker-compose.yml

# --- Optional ---
# If "true", skip docker compose build (only up -d) — faster when image unchanged.
# SKIP_BUILD=false

# If "true", only pack and upload + extract; do not run docker.
# DRY_RUN=false
