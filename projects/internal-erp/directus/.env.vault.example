# .env.vault.example
# Copy to .env.vault (gitignored) and fill in your Vault credentials.
# Then run the fetch script to populate .env and .roo/mcp.json from Vault.
#
# Windows (PowerShell):
#   Copy-Item .env.vault.example .env.vault
#   # Edit .env.vault with your token
#   Get-Content .env.vault | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#   .\vault-fetch-secrets.ps1
#
# Linux / GCP VM (bash):
#   cp .env.vault.example .env.vault
#   # Edit .env.vault with your token
#   set -a && source .env.vault && set +a
#   bash vault-fetch-secrets.sh

# ── Vault connection ─────────────────────────────────────────────────────────
VAULT_ADDR=https://45.88.223.83:31313
VAULT_TOKEN=hvs.YOUR_TOKEN_HERE

# ── Optional overrides ───────────────────────────────────────────────────────
# Secret path in Vault cubbyhole (KV v1 — no /data/ prefix).
# Default used by scripts if not set:
# VAULT_SECRET_PATH=cubbyhole/internal-erp/db

# Set to "true" if Vault uses a self-signed TLS certificate (it does — 45.88.223.83):
# VAULT_SKIP_TLS=true

# Set to "true" to preview output without writing any files:
# DRY_RUN=true
