# Copy to deploy-directus-gcp.env (same folder) and fill in. Do not commit deploy-directus-gcp.env.
# Used by: .\deploy-directus-gcp.ps1

# --- GCP (required) ---
GCP_PROJECT=your-gcp-project-id
GCP_REGION=europe-west6

# Artifact Registry Docker repo (create once):
#   gcloud artifacts repositories create REPO_NAME --repository-format=docker --location=GCP_REGION
AR_REPOSITORY=directus
IMAGE_NAME=internal-erp-directus
IMAGE_TAG=latest

# Cloud SQL instance connection name (project:region:instance)
CLOUDSQL_INSTANCE=your-project:europe-west6:your-instance

# Cloud Run service name (created or updated by deploy)
CLOUD_RUN_SERVICE=directus-erp

# Runtime service account email (must have roles/cloudsql.client on the instance)
# Create: gcloud iam service-accounts create directus-cloudrun --display-name="Directus Cloud Run"
# Grant:  gcloud projects add-iam-policy-binding PROJECT --member="serviceAccount:..." --role="roles/cloudsql.client"
RUNTIME_SERVICE_ACCOUNT=directus-cloudrun@YOUR_PROJECT.iam.gserviceaccount.com

# --- Directus secrets (required) ---
# KEY must be a 32-character random string for Directus 11
DIRECTUS_KEY=replace-with-32-char-random-string
DIRECTUS_SECRET=replace-with-long-random-string

# --- PostgreSQL (same DB as local; Cloud Run connects via Unix socket) ---
DB_DATABASE=bidstruct4
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Match your local .env / mixed-case schema
DB_SEARCH_PATH__0=BS4Prod09Feb2026
DB_SEARCH_PATH__1=public

# Optional: extra Directus env (comma-separated KEY=VAL for gcloud, no spaces around =)
# EXTRA_ENV_VARS=AUTH_PROVIDERS=google,CACHE_ENABLED=true

# --- Access ---
# If true, anyone can hit the URL (Directus still enforces login). Set false to require IAM on Cloud Run.
ALLOW_UNAUTHENTICATED=true

# --- Cloud Run sizing ---
CLOUD_RUN_MEMORY=2Gi
CLOUD_RUN_CPU=2
CLOUD_RUN_TIMEOUT=300
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=3

# --- Local Docker (optional overrides) ---
# DOCKER_BUILD_PLATFORM=linux/amd64
