# Copy to .env on the GCP VM (same folder as docker-compose.gcp-vm.yml).
# Never commit real values. docker-compose.gcp-vm.yml sets DB_HOST=cloud-sql-proxy and DB_PORT=5432.
#
# REQUIRED for compose variable substitution (cloud-sql-proxy service):
CLOUD_SQL_INSTANCE=expertflowerp:REGION:YOUR_CLOUD_SQL_INSTANCE_NAME
#
# Directus (same keys as .env.example; adjust for production):
# KEY=
# SECRET=
# PUBLIC_URL=https://directus.yourdomain.com
# DB_CLIENT=pg
# DB_DATABASE=bidstruct4
# DB_USER=sterile_dev
# DB_PASSWORD=
# DB_SEARCH_PATH__0=BS4Prod09Feb2026
# DB_SEARCH_PATH__1=public
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# Story 1-8 Google SSO — add production origins/redirects in Google Console:
# AUTH_PROVIDERS=google
# AUTH_GOOGLE_DRIVER=openid
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# ... (see .env.example)
